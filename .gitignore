# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

# Temporary files
*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
$RECYCLE.BIN/

# Logs
*.log
log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Source maps / coverage / versions
/.sourcemaps
/.versions
/coverage
/coverage/
/libpeerconnection.log
testem.log

# Ionic
/.ionic
/www
/platforms
/plugins

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Angular
/.angular
/.angular/cache

# Nx
/.nx
/.nx/cache

# Node
/node_modules

# Capacitor / Android build output
/android/.gradle/
/android/build/
/android/app/build/
/android/app/release/
/android/app/debug/

# Android local machine config
/android/local.properties

# Android Studio / IntelliJ
.idea/
android/.idea/
*.iml
/android/*.iml
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Keystores / app signing
*.jks
*.keystore
*.p12
*.pem

# Environment / secrets
.env
.env.*
!.env.example

# Sass / typings / misc
.sass-cache/
/typings
/connect.lock

# System files
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate